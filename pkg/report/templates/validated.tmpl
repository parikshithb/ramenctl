{{define "validated" -}}
{{- if isTruncated .Value .MaxLen -}}
<span class="value" title="{{.Value}}">{{truncate .Value .MaxLen}}</span>
{{- else -}}
<span class="value">{{.Value}}</span>
{{- end}}
<span class="state">{{icon .State}}</span>
{{- if .Description}}
<p class="description">{{.Description}}</p>
{{- end}}
{{- end}}
