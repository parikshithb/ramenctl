{{define "s3" -}}
<dl class="validation">
    <dt>Profiles</dt>
    <dd>
        <span class="value">{{len .Value}}</span>
        <span class="state">{{icon .State}}</span>
        {{- if .Description}}
            <p class="description">{{.Description}}</p>
        {{- end}}
    </dd>
</dl>
{{- range .Value}}
    <section>
        <h4>{{.Name}}</h4>
        <dl class="validation">
            <dt>Accessible</dt>
            <dd>{{template "validated" .Accessible}}</dd>
        </dl>
    </section>
{{- end}}
{{- end}}
